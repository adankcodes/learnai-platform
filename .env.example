# Copy this file to .env and fill in real values before running.

# Get a key from https://console.groq.com/keys
# If left blank, the server runs in MOCK MODE: it returns canned but
# structurally realistic tutor responses so you can demo the full
# product flow without spending API credits.
GROQ_API_KEY=

# Any long random string. Used to sign login sessions (JWTs).
JWT_SECRET=change-this-to-a-long-random-string

# Port the Express server listens on.
PORT=3000

# Which Groq-hosted model to call. See https://console.groq.com/docs/models
# for the current list — llama-3.3-70b-versatile is a solid general default.
GROQ_MODEL=llama-3.3-70b-versatile
